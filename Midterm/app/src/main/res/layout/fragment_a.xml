<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/as_fragment_a_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#F5F7FA">

    <!-- Title -->
    <TextView
        android:id="@+id/as_text_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:gravity="center"
        android:text="Personal Finance Manager"
        android:textColor="#1A1A2E"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/as_text_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="შეიყვანეთ მონაცემები"
        android:textColor="#666680"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/as_text_title" />

    <!-- Salary -->
    <TextView
        android:id="@+id/as_label_salary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="ხელფასი"
        android:textColor="#444460"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/as_text_subtitle" />

    <EditText
        android:id="@+id/as_edit_salary"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/edit_text_bg"
        android:hint="მაგ. 3000"
        android:inputType="numberDecimal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="#1A1A2E"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/as_label_salary" />

    <!-- Rent -->
    <TextView
        android:id="@+id/as_label_rent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="ქირა"
        android:textColor="#444460"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/as_edit_salary" />

    <EditText
        android:id="@+id/as_edit_rent"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/edit_text_bg"
        android:hint="მაგ. 1000"
        android:inputType="numberDecimal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="#1A1A2E"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/as_label_rent" />

    <!-- Meals -->
    <TextView
        android:id="@+id/as_label_meals"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="კვება"
        android:textColor="#444460"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/as_edit_rent" />

    <EditText
        android:id="@+id/as_edit_meals"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/edit_text_bg"
        android:hint="მაგ. 300"
        android:inputType="numberDecimal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="#1A1A2E"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/as_label_meals" />

    <!-- Calculate Button -->
    <Button
        android:id="@+id/as_btn_calculate"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="36dp"
        android:backgroundTint="#4F46E5"
        android:text="გამოთვლა"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/as_edit_meals" />

</androidx.constraintlayout.widget.ConstraintLayout>